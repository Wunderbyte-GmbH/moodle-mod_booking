{
  "name": "vue-3",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "scripts": {
    "build": "cross-env webpack --mode production --progress",
    "serve": "cross-env webpack serve --mode development --progress",
    "test:unit": "echo \"Unit tests need migration from Vue CLI to Jest/Vitest\" && exit 1",
    "test:unit:ci": "echo \"Unit tests need migration from Vue CLI to Jest/Vitest\" && exit 1",
