    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-input-autowidth": "^1.0.11",
    "vue-router": "^5.0.4",
