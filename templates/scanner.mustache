{{!
    @template mod_booking/scanner

    SofaTicket entry scanner UI.

    Classes required for JS:
    * data-region="scanner-*" and data-action="scanner-*" hooks are read by mod_booking/scanner.

    Context variables required for this template:
    * cmid int The booking course module id.

    Example context (json):
    {
        "cmid": 42
    }
}}
<div class="booking-scanner" data-region="scanner" data-cmid="{{cmid}}">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="badge badge-secondary p-2" data-region="scanner-counter">{{#str}} ticketscannercounter, mod_booking, {"present": "0", "booked": "0"} {{/str}}</span>
        <button type="button" class="btn btn-primary" data-action="scanner-start">{{#str}} ticketscannerstart, mod_booking {{/str}}</button>
    </div>

    <div class="scanner-video-wrap position-relative bg-dark rounded" data-region="scanner-video-wrap" style="min-height: 240px;">
        <video data-region="scanner-video" class="w-100 rounded" muted playsinline autoplay style="max-height: 60vh; object-fit: cover;"></video>
    </div>

    <div class="alert mt-3 d-none" role="status" aria-live="assertive" data-region="scanner-result">
        <h4 class="mb-1" data-region="scanner-result-headline"></h4>
        <div class="font-weight-bold" data-region="scanner-result-name"></div>
        <div data-region="scanner-result-event"></div>
        <div class="small" data-region="scanner-result-detail"></div>
    </div>

    <div class="text-muted small mt-2" data-region="scanner-status">{{#str}} ticketscannerstartprompt, mod_booking {{/str}}</div>
</div>
