{{!
    @template mod_booking/report/navigation_breadcrumbs

    Bootstrap breadcrumb navigation between the scopes of the Bookings Tracker
    (report2.php: system, course, instance, option, optiondate).

    Each item shows the localized scope label in small print above the name.
    Ancestor scopes link to their report2.php view (or are plain text without
    the capability), the current scope links out to its own page in a new tab.
    In option and optiondate scope, a Bootstrap dropdown lists all optiondates
    (sessions) of the booking option - plain links, no JS involved.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Example context (json):
    {
        "items": [
            {"label": "Site", "name": "My Moodle site", "url": "https://example.com/mod/booking/report2.php", "active": false},
            {"label": "Booking option", "name": "Yoga course", "active": true,
             "pageurl": "https://example.com/mod/booking/view.php?id=2&optionid=1&whichview=showonlyone",
             "pagelinktitle": "Open \"Yoga course\" in a new tab"}
        ],
        "sessionsdropdown": {
            "label": "Date",
            "toggletext": "Choose date (session)...",
            "active": false,
            "sessions": [
                {"prettydate": "Mo, 28.01.2025, 12:00-13:00",
                 "url": "https://example.com/mod/booking/report2.php?optionid=1&optiondateid=5",
                 "current": false}
            ]
        }
    }
}}
<nav aria-label="{{#str}} report2breadcrumbs, mod_booking {{/str}}" class="report2-nav">
    <ol class="breadcrumb report2-breadcrumb mb-0">
        {{#items}}
        <li class="breadcrumb-item{{#active}} active{{/active}}"{{#active}} aria-current="page"{{/active}}>
            <span class="report2-breadcrumb-box d-inline-flex flex-column">
                <span class="report2-breadcrumb-label small text-muted">{{label}}</span>
                <span class="report2-breadcrumb-name">
                    {{#url}}<a href="{{url}}">{{name}}</a>{{/url}}
                    {{^url}}{{name}}{{/url}}
                    {{#pageurl}}
                    <a href="{{pageurl}}" target="_blank" rel="noopener" class="report2-breadcrumb-pagelink"
                        title="{{pagelinktitle}}" aria-label="{{pagelinktitle}}">
                        <i class="fa fa-xs fa-external-link" aria-hidden="true"></i>
                    </a>
                    {{/pageurl}}
                </span>
            </span>
        </li>
        {{/items}}
        {{#sessionsdropdown}}
        <li class="breadcrumb-item{{#active}} active{{/active}}"{{#active}} aria-current="page"{{/active}}>
            {{! The wrappers are divs (not spans like in the other crumbs), because the
                dropdown-menu div is flow content and must not sit inside a span. }}
            <div class="report2-breadcrumb-box d-inline-flex flex-column">
                <span class="report2-breadcrumb-label small text-muted">{{label}}</span>
                <div class="report2-breadcrumb-name dropdown d-inline-block">
                    <button type="button" class="btn btn-link p-0 report2-sessions-toggle dropdown-toggle"
                        data-toggle="dropdown" data-bs-toggle="dropdown" aria-expanded="false">{{toggletext}}</button>
                    <div class="dropdown-menu report2-sessions-menu">
                        {{#sessions}}
                        <a class="dropdown-item{{#current}} active{{/current}}"
                            href="{{url}}"{{#current}} aria-current="page"{{/current}}>{{prettydate}}</a>
                        {{/sessions}}
                    </div>
                </div>
            </div>
        </li>
        {{/sessionsdropdown}}
    </ol>
</nav>
