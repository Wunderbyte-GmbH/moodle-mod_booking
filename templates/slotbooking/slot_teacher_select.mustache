{{!
    @template mod_booking/slotbooking/slot_teacher_select

    Per-slot teacher (examiner) selection for the slot booking picker. The
    condition/slotBooking picker computes the option lists and wires the change
    handlers; this template only renders the markup.

    Context variables required for this template:
    * heading - Heading text, e.g. "Examiners per slot: 2".
    * rows - One entry per selected slot.
        * slotkey - Slot key "start:end".
        * slotlabel - Slot label "<day> · <time range>".
        * multiple - Whether multiple teachers can be picked.
        * size - Visible option count for multi-selects.
        * showempty - Whether to render the leading empty option (single-select).
        * options - Selectable teachers.
            * value - Teacher id.
            * label - Teacher full name.
            * selected - Whether the teacher is currently selected.

    Example context (json):
    {
        "heading": "Examiners per slot: 1",
        "rows": [
            {
                "slotkey": "1620:1640",
                "slotlabel": "Monday, 7 May 2046 · 4:00 PM - 4:40 PM",
                "multiple": false,
                "size": 0,
                "showempty": true,
                "options": [
                    {"value": "5", "label": "Teacher 1", "selected": false}
                ]
            }
        ]
    }
}}
<div class="small fw-bold mb-2">{{heading}}</div>
{{#rows}}
    <div class="mb-2 p-2 border rounded">
        <div class="small fw-bold mb-1">{{slotlabel}}</div>
        <select class="form-control form-control-sm" data-slot-key="{{slotkey}}"{{#multiple}} multiple size="{{size}}"{{/multiple}}>
            {{#showempty}}
                <option value="">-</option>
            {{/showempty}}
            {{#options}}
                <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
            {{/options}}
        </select>
    </div>
{{/rows}}
