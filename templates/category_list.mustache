{{!
    @template mod_booking/category_list

    Displays a nested list of booking categories with edit and delete links.
    The template includes itself to render subcategories recursively.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * hascategories - whether there are categories on this level
    * categories - array of categories, each with name, editurl, deleteurl
      and (recursively) hascategories/categories for its subcategories

    Example context (json):
    {
        "hascategories": true,
        "categories": [
            {
                "name": "Sports",
                "editurl": "#",
                "deleteurl": "#",
                "hascategories": true,
                "categories": [
                    {
                        "name": "Tennis",
                        "editurl": "#",
                        "deleteurl": "#",
                        "hascategories": false,
                        "categories": []
                    }
                ]
            }
        ]
    }
}}
{{#hascategories}}
<ul>
    {{#categories}}
    <li>
        {{name}} -
        <a href="{{editurl}}">{{#str}} editcategory, mod_booking {{/str}}</a> -
        <a href="{{deleteurl}}">{{#str}} deletecategory, mod_booking {{/str}}</a>
        {{> mod_booking/category_list }}
    </li>
    {{/categories}}
</ul>
{{/hascategories}}
