{{!
    @template mod_booking/button_row

    Displays a horizontal row of single buttons.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * buttons - array of exported core\output\single_button contexts
    * classes - optional additional classes for the wrapping element

    Example context (json):
    {
        "classes": "justify-content-center mt-2",
        "buttons": [
            {
                "method": "get",
                "url": "#",
                "label": "Cancel"
            },
            {
                "method": "get",
                "url": "#",
                "label": "Add new rule"
            }
        ]
    }
}}
<div class="d-flex flex-wrap align-items-center gap-1 {{classes}}">
    {{#buttons}}
        {{> core/single_button }}
    {{/buttons}}
</div>
