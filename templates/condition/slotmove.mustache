{{!
    @template mod_booking/condition/slotmove

    Self-service "Update booking" prepage: one editor for move + cancel + change. The current slots
    are pre-selected; deselecting cancels, switching moves/changes. Driven by the slotupdate_form
    DynamicForm (the picker is rendered by the form, hydrated from the embedded slot snapshot) and
    routed through slot_update_service — no dedicated cancel list, no move_slot webservice.

    Data attributes required for JS:
    * data-optionid
    * data-userid
    * data-baid
    * data-selfservice

    Example context (json):
    {
        "optionid": 42,
        "userid": 5,
        "baid": 99,
        "cmid": 12
    }
}}
<div class="booking-slotupdate-prepage" id="booking-slotupdate-{{optionid}}"
     data-optionid="{{optionid}}" data-userid="{{userid}}" data-baid="{{baid}}" data-cmid="{{cmid}}"
     data-selfservice="1">
    <p class="mb-2">{{#str}}slot_update_tab, mod_booking{{/str}}</p>
    <div data-region="slotupdate-form"></div>
    <button type="button" class="btn btn-primary mt-2" data-action="slotupdate-submit">
        {{#str}}slot_update_button, mod_booking{{/str}}
    </button>
</div>
{{#js}}
require(['mod_booking/condition/slotUpdate'], function(mod) {
    mod.init('booking-slotupdate-{{optionid}}');
});
{{/js}}
